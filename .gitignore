# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a multi-platform environment, the lock file may not be portable.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies, which may not be portable.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains specific versions of dependencies
.pdm-plugins/
pdm.lock
pdm.toml

# PEP 582; dependency directory created by pipflow (.pdm-build/ is used by pdm)
